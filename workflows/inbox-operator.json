    {
      "parameters": {
        "jsCode": "const resume = $input.first().json;\nconst decision =\n  resume.query?.decision ||\n  resume.decision ||\n  (resume.body && resume.body.decision) ||\n  \"unknown\";\n\nconst draft = $('Prepare Draft').first().json;\n\nreturn [\n  {\n    json: {\n      decision: decision,\n      approved: decision === \"approve\",\n      draftText: draft.draftText,\n      threadId: draft.threadId,\n      emailId: draft.emailId,\n      toAddress: draft.toAddress,\n      replySubject: draft.replySubject,\n      intent: draft.intent,\n      priority: draft.priority\n    }\n  }\n];"
