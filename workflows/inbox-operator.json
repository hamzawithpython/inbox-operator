    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  model: \"llama-3.3-70b-versatile\",\n  temperature: 0,\n  response_format: { type: \"json_object\" },\n  messages: [\n    {\n      role: \"system\",\n      content: \"You are an email triage router. Classify the email into exactly one category and return STRICT JSON only. Schema: {\\\"category\\\": one of [\\\"high_priority\\\",\\\"customer_support\\\",\\\"finance\\\",\\\"promotion\\\",\\\"other\\\"], \\\"priority\\\": one of [\\\"high\\\",\\\"normal\\\",\\\"low\\\"], \\\"reason\\\": short one-sentence justification, \\\"needs_reply\\\": boolean}. Rules: high_priority = urgent/time-sensitive/escalation needing immediate human attention; customer_support = questions, help requests, product/service issues; finance = invoices, payments, billing, financial matters; promotion = marketing, newsletters, sales pitches, offers (these are NOT replied to); other = anything else needing a reply. Base classification only on the email content.\"\n    },\n    {\n      role: \"user\",\n      content: \"Subject: \" + ($json.subject || \"\") + \"\\n\\nFrom: \" + ($json.from.value[0].name || \"\") + \" <\" + ($json.from.value[0].address || \"\") + \">\\n\\nBody:\\n\" + ($json.text || $json.snippet || \"\")\n    }\n  ]\n}) }}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        -176,
        -352
      ],
      "id": "7b6532fd-45d2-4105-a6c5-6389851d2d14",
      "name": "Classify Intent",
      "credentials": {
        "httpHeaderAuth": {
          "id": "Zh98zCykT2KnQ8Uu",
          "name": "Groq API"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const groqResponse = $input.first().json;\nconst rawContent = groqResponse.choices[0].message.content;\n\nlet classification;\ntry {\n  classification = JSON.parse(rawContent);\n} catch (e) {\n  classification = {\n    category: \"other\",\n    priority: \"normal\",\n    reason: \"Could not parse classifier output: \" + e.message,\n    needs_reply: true\n  };\n}\n\nconst email = $('Gmail Trigger').first().json;\n\nreturn [\n  {\n    json: {\n      category: classification.category,\n      priority: classification.priority,\n      reason: classification.reason,\n      needs_reply: classification.needs_reply,\n      emailId: email.id,\n      threadId: email.threadId,\n      subject: email.subject || \"\",\n      fromName: email.from?.value?.[0]?.name || \"\",\n      fromAddress: email.from?.value?.[0]?.address || \"\",\n      bodyText: email.text || email.snippet || \"\"\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        16,
        -352
      ],
      "id": "a07e61d3-ede4-48a4-be83-6cb09f4b90b1",
      "name": "Parse Classification"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  model: \"llama-3.3-70b-versatile\",\n  temperature: 0.4,\n  messages: [\n    {\n      role: \"system\",\n      content: \"You are drafting a reply on behalf of the inbox owner. Write a concise, professional, friendly email reply to the message below. Match the sender's tone. Do not invent specific facts, commitments, dates, or prices that are not in the original email — if a decision is needed, keep it open and defer to the inbox owner. Output ONLY the email body text: no subject line, no 'Subject:', no markdown, no placeholders like [Your Name]. Sign off as 'Best regards'.\"\n    },\n    {\n      role: \"user\",\n      content: \"This email was classified as intent=\" + $json.intent + \", priority=\" + $json.priority + \".\\n\\nReply to this email:\\n\\nFrom: \" + $json.fromName + \"\\nSubject: \" + $json.subject + \"\\n\\n\" + $json.bodyText\n    }\n  ]\n}) }}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        864,
        -848
      ],
      "id": "1b3dafc7-4692-49e2-a49a-0d814a69c089",
      "name": "Draft Reply",
      "credentials": {
        "httpHeaderAuth": {
          "id": "Zh98zCykT2KnQ8Uu",
          "name": "Groq API"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Pull the AI-generated reply text from the Draft Reply (Groq) response.\nconst draftText = $input.first().json.choices[0].message.content.trim();\n\n// Reach back to Parse Classification for the email metadata.\nconst meta = $('Parse Classification').first().json;\n\nreturn [\n  {\n    json: {\n      draftText: draftText,\n      threadId: meta.threadId,\n      emailId: meta.emailId,\n      subject: meta.subject,\n      toAddress: meta.fromAddress,   // we reply TO the original sender\n      toName: meta.fromName,\n      intent: meta.intent,\n      priority: meta.priority,\n      // pre-build the reply subject (Re: ...) once, reused downstream\n      replySubject: meta.subject.startsWith(\"Re:\") ? meta.subject : \"Re: \" + meta.subject\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        688,
        -592
      ],
